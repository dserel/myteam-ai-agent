# Streamlit secrets — copy to .streamlit/secrets.toml και συμπλήρωσε.
# Στο Streamlit Cloud → App settings → Secrets, paste το ίδιο.
#
# ΠΟΤΕ μην κάνεις commit το πραγματικό secrets.toml.

# === LLM (Anthropic Claude) ===
ANTHROPIC_API_KEY = ""           # sk-ant-...
CLAUDE_MODEL = "claude-sonnet-4-6"   # ή "claude-haiku-4-5-20251001" για φθηνότερο

# === Weather (OpenWeather, για parent heads-up) ===
OPENWEATHER_API_KEY = ""
WEATHER_CITY = "Glyfada,GR"

# === Metabase ===
METABASE_URL = "https://metabase.myteam.gr"
METABASE_API_KEY = ""               # preferred (δεν λήγει)
METABASE_SESSION = ""               # εναλλακτικό
METABASE_DATABASE_ID = "2"

# === Supabase (Phase B: feedback storage) ===
SUPABASE_URL = ""                   # https://xxxx.supabase.co
SUPABASE_SERVICE_KEY = ""           # service_role key (Settings → API)

# === Defaults for UI ===
DEFAULT_CLUB_ID = "41"

# === Auth (hardcoded users) ===
[auth]
cookie_name = "myteam_ai_agent_auth"
cookie_key = "ΑΛΛΑΞΕ-ΑΥΤΟ-ΣΕ-RANDOM-STRING-32+CHARS"
cookie_expiry_days = 7

[[auth.users]]
username = "dimitris"
name = "Dimitris"
role = "admin"
password_hash = "$2b$12$REPLACE_ME_WITH_BCRYPT_HASH"

[[auth.users]]
username = "manager_glyfada"
name = "Manager Γλυφάδας"
role = "user"
password_hash = "$2b$12$REPLACE_ME_WITH_BCRYPT_HASH"

# Για να φτιάξεις bcrypt hash:
#   python scripts/make_password_hash.py "MyPassword123"
